{
  "openapi": "3.1.0",
  "info": {
    "title": "Document Search API",
    "version": "0.1.0",
    "description": "API for document storage in PostgreSQL with full-text search via Elasticsearch"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
